# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/unsa_career_connect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Groq API (LLM - FREE TIER AVAILABLE: https://console.groq.com)
